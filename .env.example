# Supabase — copy values from Settings → API + Settings → Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# Postgres — for Drizzle. Use the pooled (transaction mode) URL on port 6543 for app queries.
# For drizzle-kit migrations, also supports the direct URL on port 5432.
# IMPORTANT: copy the pooled URL DIRECTLY from Supabase Dashboard → Settings → Database
# → Connection string → Transaction. The pooler hostname is aws-0, aws-1, or aws-2 depending
# on which physical pooler your project lives on — do NOT assume aws-0; check your dashboard.
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-X-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Brave Search — used by the forum-domain adapter (filtered to forum URLs).
BRAVE_SEARCH_API_KEY=

# Tavily — general web search adapter for evidence-grounded AI diagnostics.
# Free tier: 1000 credits/mo, no card. Sign up at https://tavily.com/
TAVILY_API_KEY=

# YouTube
YOUTUBE_API_KEY=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=vyntechs/1.0 (+https://vyntechs.com)

# Voyage AI — embeddings for corpus retrieval (Phase K).
# Anthropic-recommended provider; voyage-3 model emits 1024-dim vectors.
# Free tier 200M tokens/month at https://dash.voyageai.com/
VOYAGE_API_KEY=

# Vercel Cron — shared secret used to authenticate cron requests.
# Generate with: openssl rand -hex 32
# Vercel sends `Authorization: Bearer ${CRON_SECRET}` on cron invocations.
# Local dev leaves this unset; the cron route is open on localhost only.
CRON_SECRET=

# Founder knowledge base — Supabase auth user UUID of the shop owner
# authorized to dump free-form notes into founder_notes_queue. Only this
# user can submit notes; curators can still review/promote/dismiss them.
# Leave unset in any env where founder ingestion should stay disabled.
FOUNDER_USER_ID=

# Feature flags
NEXT_PUBLIC_DESKTOP_INTAKE_ENABLED=false
